{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/claude-pre-commit-checks.sh"
          }
        ]
      }
    ]
  }
}
